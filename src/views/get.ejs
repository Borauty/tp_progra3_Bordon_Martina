<%- include("partials/head.ejs", { titulo: "Admin - Consultar", script: "get.js", cssExtra: ["get.css"] }) %>
<%- include("partials/navAdmin.ejs", { activo: "consultar" }) %>

<main class="contenido-principal">
    <section class="form-productos">
        <h2>Consultar producto por id</h2>
        <form id="formularioConsultar">
            <label for="idProd">Id del producto</label>
            <input type="number" name="idProd" id="idProd" required>
            <input type="submit" value="Consultar producto">
        </form>
    </section>

    <section class="seccion-productos">
        <h2>Resultado</h2>
        <div id="contenedor-productos"></div>
    </section>
</main>

<%- include("partials/footer.ejs") %>